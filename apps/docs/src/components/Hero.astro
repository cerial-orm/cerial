---
// Hero.astro — Static hero section for the Cerial docs landing page
---

<section class="relative py-24 md:py-40">
  <div class="mx-auto max-w-3xl px-6 text-center">
    <h1
      class="text-5xl font-bold tracking-tight text-white sm:text-6xl md:text-7xl"
    >
      Cerial
    </h1>
    <p class="mt-6 text-lg text-zinc-400 md:text-xl">
      A Prisma-like ORM for SurrealDB
    </p>
    <p class="mt-3 text-base text-zinc-500">
      Schema-driven code generation and full TypeScript type safety
    </p>
    <div
      class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
    >
      <a
        href="/cerial/getting-started/"
        class="inline-flex items-center rounded-lg bg-white px-6 py-3 text-sm font-medium text-zinc-900 transition-colors hover:bg-zinc-200 no-underline"
      >
        Get Started
      </a>
      <a
        href="https://github.com/user/cerial"
        class="inline-flex items-center rounded-lg border border-zinc-700 px-6 py-3 text-sm font-medium text-zinc-300 transition-colors hover:bg-zinc-800 no-underline"
      >
        View on GitHub
      </a>
    </div>
  </div>
</section>
