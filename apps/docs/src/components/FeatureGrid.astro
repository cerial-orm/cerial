---
// FeatureGrid.astro — 8-card grid showcasing Cerial's main capabilities

const features = [
  {
    icon: '📐',
    title: 'Schema-First',
    description: 'Define models in .cerial files with clean, readable syntax',
  },
  {
    icon: '🔒',
    title: 'Type-Safe Client',
    description: 'Generated TypeScript types with full IntelliSense',
  },
  {
    icon: '🔗',
    title: 'Relations',
    description: '1:1, 1:N, N:N with nested create, connect, disconnect',
  },
  {
    icon: '🎯',
    title: 'Dynamic Types',
    description: 'Return types narrow based on select and include',
  },
  {
    icon: '💫',
    title: 'Transactions',
    description: 'Array, callback, and manual modes with retry',
  },
  {
    icon: '⚡',
    title: 'CLI Tooling',
    description: 'Generate, format, watch, and migrate in one command',
  },
  {
    icon: '🧩',
    title: 'VS Code Extension',
    description: 'Completions, diagnostics, formatting, and navigation',
  },
  {
    icon: '🗄️',
    title: 'SurrealDB Native',
    description: "Built for SurrealDB's multi-model capabilities",
  },
];
---

<section class="py-16">
  <div class="mx-auto max-w-6xl px-4">
    <h2 class="mb-10 text-center text-2xl font-semibold text-white md:text-3xl">
      Everything you need
    </h2>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4 items-stretch [&>*]:mt-0">
      {
        features.map((f) => (
          <div class="group flex h-full flex-col rounded-lg border border-zinc-800 bg-zinc-900/50 p-6 transition-colors hover:border-zinc-700 hover:bg-zinc-900/80">
            <span class="block text-2xl">{f.icon}</span>
            <h3 class="mt-3 text-sm font-semibold text-white">{f.title}</h3>
            <p class="mt-1 text-sm leading-relaxed text-zinc-400">
              {f.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
