---
// SectionCards.astro — Grid of clickable cards linking to major doc sections

const sections = [
  {
    title: 'Getting Started',
    description: 'Install, define schemas, generate your client, run queries',
    href: '/cerial/getting-started/',
  },
  {
    title: 'Schema',
    description:
      'Field types, decorators, arrays, enums, literals, inheritance',
    href: '/cerial/schema/',
  },
  {
    title: 'Relations',
    description: '1:1, 1:N, N:N, nested operations, cascade behavior',
    href: '/cerial/relations/',
  },
  {
    title: 'Queries',
    description: 'CRUD, upsert, count, exists, transactions, hooks',
    href: '/cerial/queries/',
  },
  {
    title: 'Filtering',
    description: 'Comparison, string, array, logical, nested operators',
    href: '/cerial/filtering/',
  },
  {
    title: 'Select & Include',
    description: 'Dynamic return types, field selection, relation includes',
    href: '/cerial/select-and-include/',
  },
  {
    title: 'Objects & Tuples',
    description: 'Embedded types with select, filtering, partial updates',
    href: '/cerial/objects/',
  },
  {
    title: 'Type System',
    description: 'CerialId, NONE vs null, wrapper classes, generated types',
    href: '/cerial/types/',
  },
  {
    title: 'CLI',
    description: 'Generate, format, init, watch, multi-schema, path filtering',
    href: '/cerial/cli/',
  },
  {
    title: 'VS Code Extension',
    description: 'Syntax highlighting, completions, diagnostics, formatting',
    href: '/cerial/extension/',
  },
];
---

<section class="py-16">
  <div class="mx-auto max-w-6xl px-4">
    <h2 class="mb-8 text-center text-2xl font-semibold text-white md:text-3xl">
      Explore the docs
    </h2>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {
        sections.map((s) => (
          <a
            href={s.href}
            class="group flex items-start justify-between rounded-lg border border-zinc-800 bg-zinc-900/50 px-5 py-4 transition-all hover:border-zinc-600 hover:bg-zinc-900/80"
          >
            <div class="min-w-0">
              <h3 class="text-sm font-semibold text-white">{s.title}</h3>
              <p class="mt-1 text-[13px] leading-relaxed text-zinc-400">
                {s.description}
              </p>
            </div>
            <span class="ml-4 mt-0.5 shrink-0 text-zinc-600 transition-all group-hover:translate-x-0.5 group-hover:text-zinc-300">
              →
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
