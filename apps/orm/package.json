{
  "name": "cerial",
  "version": "0.1.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "cerial": "./dist/bin/cerial.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./parser": {
      "types": "./dist/parser/index.d.mts",
      "import": "./dist/parser/index.mjs",
      "require": "./dist/parser/index.cjs"
    },
    "./generators": {
      "types": "./dist/generators/index.d.mts",
      "import": "./dist/generators/index.mjs",
      "require": "./dist/generators/index.cjs"
    },
    "./query": {
      "types": "./dist/query/index.d.mts",
      "import": "./dist/query/index.mjs",
      "require": "./dist/query/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.mts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.cjs"
    },
    "./cli": {
      "types": "./dist/cli/index.d.mts",
      "import": "./dist/cli/index.mjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.mts",
      "import": "./dist/utils/index.mjs",
      "require": "./dist/utils/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.mts",
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.cjs"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "1.3.9",
    "tsdown": "^0.21.0-beta.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@biomejs/js-api": "^4.0.0",
    "@biomejs/wasm-nodejs": "^2.4.4",
    "citty": "^0.2.1",
    "ignore": "^7.0.5",
    "surrealdb": "^2.0.0",
    "ts-toolbelt": "^9.6.0",
    "valibot": "^1.2.0",
    "fast-glob": "^3.3.3"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "prepublishOnly": "bun run build",
    "generate:test-client": "bun run bin/cerial.ts generate -s tests/e2e/schemas -o tests/e2e/generated",
    "typecheck": "tsc --noEmit -p tests/e2e/typechecks/tsconfig.json",
    "test": "bun test tests/unit/ tests/generators/ tests/parser/ tests/query/ tests/client/ tests/validators/ tests/utils/ tests/integration/",
    "test:e2e": "bun test tests/e2e/ --preload ./tests/e2e/preload.ts --concurrency 5",
    "test:full": "bun generate:test-client && bun typecheck && bun run test && bun run test:e2e",
    "format": "biome check --write ."
  }
}
