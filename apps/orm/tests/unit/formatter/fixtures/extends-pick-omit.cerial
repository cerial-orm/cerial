abstract model Timestamps {
  id        Record @id
  createdAt Date   @createdAt
  updatedAt Date   @updatedAt
}


model Immutable extends Timestamps[id, createdAt] {
  label String @readonly
}


model Slim extends Timestamps[!updatedAt] {
  name String
}


model MultiOmit extends Timestamps[!createdAt, !updatedAt] {
  code String @unique
}


object FullProfile {
  bio     String
  avatar  String?
  website String?
}


object PublicProfile extends FullProfile[bio, avatar] {
  badge String
}


object MinimalProfile extends FullProfile[!website] {
  rank Int
}
