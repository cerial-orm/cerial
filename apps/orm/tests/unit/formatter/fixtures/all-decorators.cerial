# Decorators deliberately in WRONG order for reorder testing
object FlexObj {
  street String
  city   String
}


model DecoratorReorder {
  id         Record    @id
  email      Email     @unique
  name       String
  slug       String    @index
  bio        String?   @readonly @nullable
  age        Int?      @default(0) @nullable
  authorId   Record?   @nullable
  author     Relation? @field(authorId) @model(DecoratorReorder) @key(authorKey) @onDelete(SetNull)
  tags       String[]  @set
  scores     Int[]     @distinct @sort(asc)
  stamp      Date      @updatedAt
  born       Date      @createdAt
  accessed   Date      @now
  meta       FlexObj   @flexible
  resetCount Int       @defaultAlways(0)
  token      Uuid      @uuid7
}
