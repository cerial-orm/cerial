enum Permission {
  READ,
  WRITE,
  EXECUTE
}


literal Theme {
  'light',
  'dark',
  'system'
}


tuple Dimensions {
  width Float,
  height Float
}


object ContactInfo {
  phone String
  fax   String?
}


model Organization {
  id         Record      @id
  name       String      @unique
  theme      Theme       @default('light')
  permission Permission
  size       Dimensions?
  contact    ContactInfo
  members    Relation[]  @model(Member)
}


model Member {
  id         Record     @id
  name       String
  orgId      Record
  org        Relation   @field(orgId) @model(Organization)
  permission Permission @default('READ')
  createdAt  Date       @createdAt
}
