# Provider fixes test fixture

enum Priority {
  Low
  Medium
  High
  Critical
}

literal Severity { 'Minor', 'Major', 'Blocker' }

abstract model BaseItem {
  id Record @id
  title String
  priority Priority @default(Medium)
  createdAt Date @createdAt
}

model Task {
  id Record @id
  title String
  priority Priority
  severity Severity
  dueDate Date?
  score Int?
  isActive Bool @default(true)
  status Priority @default()
  enabled Bool @default()
  taskUuid Uuid?
}


abstract model ParentForOmit {
  id Record @id
  name String
  email String
  age Int
}

model ChildPick extends ParentForOmit[name] {
}

model ChildOmit extends ParentForOmit[!name] {
}

model ChildEmpty extends ParentForOmit[] {
}