# Simple model fixture — common field types, optionals, arrays, timestamps

model User {
  id Record @id
  email Email @unique
  name String
  age Int?
  isActive Bool @default(true)
  score Float
  createdAt Date @createdAt
  updatedAt Date @updatedAt
  tags String[]
  scores Int[]
  loginDates Date[]
}

model Article {
  id Record @id
  title String
  body String?
  published Bool @default(false)
  viewCount Int @default(0)
  rating Float?
  createdAt Date @createdAt
}
