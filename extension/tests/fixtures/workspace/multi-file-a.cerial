# Multi-file A — defines types referenced by multi-file-b.cerial

enum Department { ENGINEERING, MARKETING, SALES, SUPPORT }

object ContactInfo {
  phone String
  address String?
}

model Employee {
  id Record @id
  name String
  department Department
  contact ContactInfo
  managerId Record?
  manager Relation? @field(managerId) @model(Employee)
  projects Relation[] @model(Project)
}
