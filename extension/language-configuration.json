{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [["{", "}"], ["[", "]"], ["(", ")"]],
  "autoClosingPairs": [["{", "}"], ["[", "]"], ["(", ")"], ["\"", "\""], ["'", "'"]],
  "surroundingPairs": [["{", "}"], ["[", "]"], ["(", ")"], ["\"", "\""], ["'", "'"]],
  "wordPattern": "[a-zA-Z_@][a-zA-Z0-9_]*",
  "indentationRules": {
    "increaseIndentPattern": ".*\\{\\s*$",
    "decreaseIndentPattern": "^\\s*\\}\\s*$"
  },
  "folding": {
    "markers": {
      "start": "^\\s*(model|object|tuple|enum|literal)\\s+\\w+\\s*\\{",
      "end": "^\\s*\\}"
    }
  }
}
