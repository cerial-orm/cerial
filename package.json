{
  "name": "cerial",
  "version": "0.1.0",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "cerial": "./bin/cerial.ts"
  },
  "exports": {
    ".": "./index.ts",
    "./parser": "./src/parser/index.ts",
    "./generators": "./src/generators/index.ts",
    "./query": "./src/query/index.ts",
    "./client": "./src/client/index.ts",
    "./cli": "./src/cli/index.ts",
    "./utils": "./src/utils/index.ts",
    "./types": "./src/types/index.ts"
  },
  "devDependencies": {
    "@types/bun": "1.3.9"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "prettier": "^3.8.1",
    "surrealdb": "^2.0.0-alpha.18",
    "ts-toolbelt": "^9.6.0"
  },
  "scripts": {
    "generate:test-client": "bun run bin/cerial.ts generate -o tests/e2e/generated",
    "typecheck": "tsc --noEmit -p tests/e2e/typechecks/tsconfig.json",
    "test": "bun test --concurrency 5",
    "test:full": "bun generate:test-client && bun typecheck && bun test"
  }
}
