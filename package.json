{
  "name": "cerial",
  "version": "0.1.0",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "cerial": "./bin/cerial.ts"
  },
  "exports": {
    ".": "./index.ts",
    "./parser": "./src/parser/index.ts",
    "./generators": "./src/generators/index.ts",
    "./query": "./src/query/index.ts",
    "./client": "./src/client/index.ts",
    "./cli": "./src/cli/index.ts",
    "./utils": "./src/utils/index.ts",
    "./types": "./src/types/index.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@types/bun": "1.3.9"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@biomejs/js-api": "^4.0.0",
    "@biomejs/wasm-nodejs": "^2.4.2",
    "ignore": "^7.0.5",
    "surrealdb": "^2.0.0-alpha.18",
    "ts-toolbelt": "^9.6.0"
  },
  "scripts": {
    "generate:test-client": "bun run bin/cerial.ts generate -s tests/e2e/schemas -o tests/e2e/generated",
    "typecheck": "tsc --noEmit -p tests/e2e/typechecks/tsconfig.json",
    "test": "bun test tests/unit/ tests/generators/ tests/parser/ tests/query/ tests/client/ tests/validators/ tests/utils/ tests/integration/",
    "test:e2e": "bun test tests/e2e/ --preload ./tests/e2e/preload.ts --concurrency 5",
    "test:full": "bun generate:test-client && bun typecheck && bun run test && bun run test:e2e",
    "format": "biome check --write ."
  }
}
