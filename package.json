{
  "name": "@org/lib_backend_surreal-om",
  "version": "0.1.0",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "surreal-om": "./bin/surreal-om.ts"
  },
  "exports": {
    ".": "./index.ts",
    "./parser": "./src/parser/index.ts",
    "./generators": "./src/generators/index.ts",
    "./query": "./src/query/index.ts",
    "./client": "./src/client/index.ts",
    "./cli": "./src/cli/index.ts",
    "./utils": "./src/utils/index.ts",
    "./types": "./src/types/index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "prettier": "^3.4.2",
    "surrealdb": "^2.0.0-alpha.16",
    "ts-toolbelt": "^9.6.0"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tests/e2e/typechecks/tsconfig.json",
    "generate:test": "bun run bin/surreal-om.ts generate -s tests/e2e/schemas/test.schema -o tests/e2e/generated"
  }
}
