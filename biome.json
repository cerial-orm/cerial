{
  "$schema": "https://biomejs.dev/schemas/2.4.2/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSpacing": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "style": {
        "noNonNullAssertion": "off",
        "useTemplate": {
          "level": "info",
          "fix": "safe"
        }
      },
      "suspicious": {
        "useIterableCallbackReturn": "off",
        "noGlobalIsNan": {
          "level": "warn",
          "fix": "safe"
        }
      },
      "correctness": {
        "noUnusedImports": {
          "level": "error",
          "fix": "safe"
        },
        "noUnusedFunctionParameters": {
          "level": "error",
          "fix": "safe"
        },
        "noUnusedVariables": {
          "level": "warn",
          "fix": "safe"
        }
      },
      "complexity": {
        "useOptionalChain": {
          "level": "error",
          "fix": "safe"
        },
        "useLiteralKeys": {
          "level": "info",
          "fix": "safe"
        }
      }
    }
  },
  "assist": {
    "enabled": true
  }
}
