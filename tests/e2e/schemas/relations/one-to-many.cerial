# 1-n Required Bidirectional
model Author {
  id Record @id
  name String
  email Email @unique
  posts Relation[] @model(PostRequired)
}

model PostRequired {
  id Record @id
  title String
  content String? @nullable
  authorId Record
  author Relation @field(authorId) @model(Author)
  createdAt Date @createdAt
}

# Only Comment defines relation, Article has no reverse
model Article {
  id Record @id
  title String
}

model Comment {
  id Record @id
  text String
  articleId Record? @nullable
  article Relation? @field(articleId) @model(Article)
}
