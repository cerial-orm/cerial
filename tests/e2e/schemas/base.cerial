# Standalone model with no relations - used as reference target
model Category {
  id Record @id
  name String @unique
  description String?
}

# Model demonstrating all field types and decorators
model FieldTypesExample {
  id Record @id
  username String @unique
  displayName String
  bio String?
  email Email @unique
  secondaryEmail Email?
  age Int
  score Int?
  balance Float
  rating Float?
  isActive Bool
  isVerified Bool?
  createdAt Date @createdAt
  updatedAt Date?
  birthDate Date
  tags String[]
  scores Int[]
  ratings Float[]
  loginDates Date[]
  status String @default("pending")
  retryCount Int @default(0)
}

# Model for testing numeric operations
model NumericExample {
  id Record @id
  intValue Int
  intOptional Int?
  floatValue Float
  floatOptional Float?
  intArray Int[]
  floatArray Float[]
}

# Model for testing date operations
model DateExample {
  id Record @id
  createdAt Date @createdAt
  scheduledAt Date
  completedAt Date?
  reminderDates Date[]
}

# Model for testing string operations
model StringExample {
  id Record @id
  title String @unique
  slug String @unique
  content String?
  keywords String[]
}

# Model for testing email validation
model EmailExample {
  id Record @id
  primaryEmail Email @unique
  backupEmail Email?
}

# Model for testing @distinct and @sort array decorators
model ArrayDecoratorTest {
  id Record @id
  uniqueTags String[] @distinct
  sortedScores Int[] @sort
  recentDates Date[] @sort(false)
  uniqueSortedCategories String[] @distinct @sort
  uniqueSortedPriorities Int[] @distinct @sort(false)
  normalTags String[]
  normalScores Int[]
}
