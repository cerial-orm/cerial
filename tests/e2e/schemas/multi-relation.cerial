# User can be author AND reviewer of same Document
# @key required to pair each forward relation with its reverse
model Writer {
  id String @id
  name String
  authoredDocs Relation[] @model(Document) @key(author)
  reviewedDocs Relation[] @model(Document) @key(reviewer)
}

model Document {
  id String @id
  title String
  authorId Record
  author Relation @field(authorId) @model(Writer) @key(author)
  reviewerId Record?
  reviewer Relation? @field(reviewerId) @model(Writer) @key(reviewer)
}
