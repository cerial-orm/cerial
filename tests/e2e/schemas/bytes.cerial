model BytesBasic {
  id Record @id
  name String
  payload Bytes
  metadata Bytes?
  tag Bytes @nullable
  chunks Bytes[]
}

object BytesInfo {
  content Bytes
  extra Bytes?
}

tuple BytesPair {
  Bytes,
  Bytes @nullable
}

model BytesWithObject {
  id Record @id
  name String
  details BytesInfo
}

model BytesWithTuple {
  id Record @id
  name String
  pair BytesPair
}
