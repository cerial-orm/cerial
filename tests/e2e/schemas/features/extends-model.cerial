// Abstract base models and concrete models extending them
// Tests: abstract, extends, multi-level chains, override, !!private fields

abstract model ExtBaseEntity {
  id Record @id !!private
  createdAt Date @createdAt !!private
  updatedAt Date @updatedAt
}

abstract model ExtBaseUser extends ExtBaseEntity {
  email Email @unique
  name String
  isActive Bool @default(true)
}

// Concrete model extending abstract base
model ExtUser extends ExtBaseUser {
  age Int?
  role String @default('user')
}

// Concrete model with omit (exclude specific field from base)
model ExtAdmin extends ExtBaseUser[!isActive] {
  level Int @default(1)
  permissions String[]
}

// Concrete model with pick (select specific fields from abstract base)
model ExtModerator extends ExtBaseEntity[id, createdAt] {
  email Email @unique
  name String
  bannedUntil Date?
  notes String?
}

// Override field from base
model ExtSuperAdmin extends ExtBaseUser {
  role String @default('superadmin')
  level Int @default(99)
  canDeleteUsers Bool @default(true)
}

// Abstract intermediary for ExtUser fields — enables multi-level inheritance
abstract model ExtBaseUserFull extends ExtBaseUser {
  age Int?
  role String @default('user')
}

// Multi-level inheritance: ExtPremiumUser -> ExtBaseUserFull -> ExtBaseUser -> ExtBaseEntity
model ExtPremiumUser extends ExtBaseUserFull {
  subscriptionTier String @default('basic')
  subscriptionEnd Date?
}

// Abstract intermediary for ExtAdmin fields — enables multi-level inheritance
abstract model ExtBaseAdmin extends ExtBaseUser[!isActive] {
  level Int @default(1)
  permissions String[]
}

// Another multi-level: ExtSystemAdmin -> ExtBaseAdmin -> ExtBaseUser -> ExtBaseEntity
model ExtSystemAdmin extends ExtBaseAdmin {
  systemAccess Bool @default(false)
  auditLog String[]
}

// Model with !!private on inherited fields
model ExtPrivateUser extends ExtBaseEntity {
  email Email @unique !!private
  name String !!private
  publicBio String?
}

// Model extending with multiple field types
model ExtProfile extends ExtBaseEntity {
  userId Record
  bio String?
  avatar String?
  tags String[]
  metadata Int?
}
