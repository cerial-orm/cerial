// Models with relations that extend abstract bases
// Tests FK + Relation with extends, pick/omit of relation fields

abstract model ExtRelBase {
  id Record @id !!private
  createdAt Date @createdAt !!private
  updatedAt Date @updatedAt
}

// Base with name/email
abstract model ExtRelAuthor extends ExtRelBase {
  name String
  email Email @unique
}

// Concrete author — bidirectional with ExtRelBlogPost
model ExtRelBlogAuthor extends ExtRelAuthor {
  bio String?
  posts Relation[] @model(ExtRelBlogPost)
}

// Abstract intermediary for blog post fields — enables multi-level inheritance
abstract model ExtRelBaseBlogPost extends ExtRelBase {
  title String
  content String?
  authorId Record
  author Relation @field(authorId) @model(ExtRelBlogAuthor)
}

// Concrete post extending abstract base — bidirectional with ExtRelBlogAuthor
model ExtRelBlogPost extends ExtRelBaseBlogPost {
}

// Base for owner
abstract model ExtRelOwner extends ExtRelBase {
  name String
}

// Concrete owner — single-sided optional relation to ExtRelBlogAuthor
model ExtRelProject extends ExtRelOwner {
  description String?
  ownerId Record?
  owner Relation? @field(ownerId) @model(ExtRelBlogAuthor)
}

// Base for tags
abstract model ExtRelTag extends ExtRelBase {
  name String @unique
}

// Concrete tag — bidirectional with ExtRelBlogPostTag
model ExtRelBlogTag extends ExtRelTag {
  postTags Relation[] @model(ExtRelBlogPostTag)
}

// Junction model — tag is bidirectional, post is single-sided optional
model ExtRelBlogPostTag {
  id Record @id
  postId Record?
  post Relation? @field(postId) @model(ExtRelBlogPost)
  tagId Record
  tag Relation @field(tagId) @model(ExtRelBlogTag)
}

// Extends with omit — exclude relation and FK fields (extends abstract parent)
model ExtRelPostSummary extends ExtRelBaseBlogPost[!author, !authorId] {
  summary String?
  wordCount Int?
}

// Extends with omit — exclude content and relation fields (extends abstract parent)
model ExtRelPostArchive extends ExtRelBaseBlogPost[!content, !author, !authorId] {
  archivedAt Date @createdAt
  archiveReason String?
}

// Abstract intermediary for comment fields — enables multi-level inheritance
abstract model ExtRelBaseComment extends ExtRelBase {
  content String
  parentCommentId Record?
  parentComment Relation? @field(parentCommentId) @model(ExtRelComment)
}

// Self-referential with optional single-sided relation
model ExtRelComment extends ExtRelBaseComment {
}

// Extends abstract parent with additional optional relation
model ExtRelCommentModerated extends ExtRelBaseComment {
  isApproved Bool @default(false)
  approvedBy Record?
  approver Relation? @field(approvedBy) @model(ExtRelBlogAuthor)
}
