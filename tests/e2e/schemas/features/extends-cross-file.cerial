// Models extending types from extends-model.cerial (cross-file references)
// Tests cross-file inheritance and type resolution

// Extend abstract model from extends-model.cerial
model ExtCrossUser extends ExtBaseEntity {
  email Email @unique
  username String @unique
  displayName String
  bio String?
}

// Extend concrete model from extends-model.cerial
model ExtCrossAdmin extends ExtAdmin {
  department String
  budget Float?
  teamSize Int?
}

// Extend concrete model with pick
model ExtCrossModerator extends ExtModerator[!bannedUntil] {
  warningCount Int @default(0)
  lastWarning Date?
}

// Extend multi-level model from extends-model.cerial
model ExtCrossPremium extends ExtPremiumUser {
  loyaltyPoints Int @default(0)
  referralCode String?
}

// Extend with additional relations
model ExtCrossProfile extends ExtProfile {
  owner Record
  followers Record[]
  following Record[]
}

// Extend with override
model ExtCrossPrivate extends ExtPrivateUser {
  email Email @unique
  publicBio String @default('No bio')
}

// Model referencing extended types from extends-model.cerial
model ExtCrossContainer {
  id Record @id
  user ExtCrossUser
  admin ExtCrossAdmin?
  moderator ExtCrossModerator?
  premium ExtCrossPremium?
  profile ExtCrossProfile?
}
