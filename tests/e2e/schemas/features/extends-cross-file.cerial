// Models extending types from extends-model.cerial (cross-file references)
// Tests cross-file inheritance and type resolution
// All models extend abstract parents (models can only extend abstract models)

// Extend abstract model from extends-model.cerial
model ExtCrossUser extends ExtBaseEntity {
  email Email @unique
  username String @unique
  displayName String
  bio String?
}

// Extend abstract admin base from extends-model.cerial
model ExtCrossAdmin extends ExtBaseAdmin {
  department String
  budget Float?
  teamSize Int?
}

// Extend abstract base with pick (picks id and createdAt from ExtBaseEntity)
model ExtCrossModerator extends ExtBaseEntity[id, createdAt] {
  email Email @unique
  name String
  warningCount Int @default(0)
  lastWarning Date?
}

// Extend abstract base for user fields (same as ExtPremiumUser's parent)
model ExtCrossPremium extends ExtBaseUserFull {
  loyaltyPoints Int @default(0)
  referralCode String?
}

// Extend abstract base entity
model ExtCrossProfile extends ExtBaseEntity {
  userId Record
  bio String?
  avatar String?
  tags String[]
  metadata Int?
  owner Record
  followers Record[]
  following Record[]
}

// Extend abstract base entity (same abstract parent as ExtPrivateUser)
model ExtCrossPrivate extends ExtBaseEntity {
  email Email @unique
  name String
  publicBio String @default('No bio')
}

