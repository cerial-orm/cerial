// 3+ level deep inheritance chains (A extends B extends C)
// Tests deep inheritance resolution and field accumulation

// Level 1: Abstract base
abstract model ExtL1Base {
  id Record @id !!private
  createdAt Date @createdAt !!private
}

// Level 2: Extends L1
abstract model ExtL2Mid extends ExtL1Base {
  name String
  description String?
}

// Level 3: Extends L2
abstract model ExtL3High extends ExtL2Mid {
  tags String[]
  metadata Int?
}

// Abstract intermediary at Level 4 — enables multi-level inheritance
abstract model ExtL4Base extends ExtL3High {
  status String @default('active')
  priority Int @default(0)
}

// Level 4: Concrete model extending abstract L4Base
model ExtL4Concrete extends ExtL4Base {
}

// Alternative Level 3 from L2
abstract model ExtL3Alt extends ExtL2Mid {
  owner Record
  isPublic Bool @default(false)
}

// Level 4 from L3Alt
model ExtL4AltConcrete extends ExtL3Alt {
  viewCount Int @default(0)
  lastViewed Date?
}

// Deep chain branching at level 3 (no filter — inherits all from ExtL2Mid chain)
abstract model ExtL3Pick extends ExtL2Mid {
  category String
}

// Level 4 from L3Pick
model ExtL4PickConcrete extends ExtL3Pick {
  subcategory String?
  rank Int?
}

// Deep chain with omit at level 3
abstract model ExtL3Omit extends ExtL2Mid[!description] {
  type String
}

// Level 4 from L3Omit
model ExtL4OmitConcrete extends ExtL3Omit {
  subtype String?
  version Int @default(1)
}

// Abstract intermediary at Level 5 — enables multi-level inheritance
abstract model ExtL5Base extends ExtL4Base {
  archived Bool @default(false)
}

// Level 5: Concrete model extending abstract L5Base
model ExtL5VeryDeep extends ExtL5Base {
}

// Level 6: Concrete from abstract L5Base
model ExtL6UltraDeep extends ExtL5Base {
  archiveReason String?
  archivedAt Date?
}

