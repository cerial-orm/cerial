model User {
  id String @id
  email Email @unique
  name String
  age Int?
  isActive Bool
  createdAt Date @now
  profileId Record?
  profile Relation @field(profileId) @model(Profile)
  tagIds Record[]
  tags Relation @field(tagIds) @model(Tag)
  posts Relation @model(Post)
  nicknames String[]
  scores Int[]
  loginDates Date[]
}

model Profile {
  id String @id
  bio String?
  avatarUrl String?
  userId Record
  user Relation @field(userId) @model(User)
}

model Post {
  id String @id
  title String
  content String?
  authorId Record
  author Relation @field(authorId) @model(User)
  createdAt Date @now
}

model Tag {
  id String @id
  name String @unique
}
